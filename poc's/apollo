this is frontend.yml file 

name: Frontend - Build & Deploy

on:
  push:
    branches:
      - main
      - 'dev/**'
      - 'feature/**'
    paths:
      - 'frontend/**'

permissions:
  id-token: write
  contents: read

jobs:

  build:
    name: Build & Push Docker Image
    runs-on: ubuntu-latest

    steps:
      - name: Checkout Repository
        uses: actions/checkout@v4

      - name: Configure AWS Credentials
        uses: aws-actions/configure-aws-credentials@v4
        with:
          role-to-assume: arn:aws:iam::185863138492:role/crossaccountb
          aws-region: ap-south-1

      - name: Login to Amazon ECR
        id: login-ecr
        uses: aws-actions/amazon-ecr-login@v2

      - name: Build and Push Frontend Image
        env:
          REGISTRY: ${{ steps.login-ecr.outputs.registry }}
          REPO: atl_apac_mum_dtlk_prod_athena2.0_ecr_01
        run: |
          docker build -t $REGISTRY/$REPO:web-latest ./frontend
          docker push $REGISTRY/$REPO:web-latest


  deploy:
    name: Deploy to EC2 via SSM
    runs-on: ubuntu-latest
    needs: build 
    environment: athena-api-prod-docker

    steps:
      - name: Checkout Repository
        uses: actions/checkout@v4

      - name: Configure AWS Credentials
        uses: aws-actions/configure-aws-credentials@v4
        with:
          role-to-assume: arn:aws:iam::185863138492:role/crossaccountb
          aws-region: ap-south-1

      - name: Login to Amazon ECR
        id: login-ecr
        uses: aws-actions/amazon-ecr-login@v2

      - name: Deploy to Private EC2 via SSM
        env:
          REGISTRY: ${{ steps.login-ecr.outputs.registry }}
          REPO: atl_apac_mum_dtlk_prod_athena2.0_ecr_01
        run: |
          COMPOSE_BASE64=$(base64 -w 0 docker-compose.yml)
          ENV_BASE64=$(echo -e "DB_PASSWORD=${{ secrets.DB_PASSWORD }}\nAPI_KEY=${{ secrets.API_KEY }}" | base64 -w 0)

          aws ssm send-command \
            --targets "Key=tag:Name,Values=ATL-APAC-MUM-DTLK-PROD-ATHENA2.0-EC2-01,ATL-APAC-MUM-DTLK-PROD-ATHENA2.0-EC2-02" \
            --document-name "AWS-RunShellScript" \
            --comment "Auto-updating Frontend Service" \
            --parameters "{\"commands\":[
              \"aws ecr get-login-password --region ap-south-1 | docker login --username AWS --password-stdin $REGISTRY\",
              \"mkdir -p /home/ec2-user/athena-app\",
              \"cd /home/ec2-user/athena-app\",
              \"echo '$COMPOSE_BASE64' | base64 -d > /home/ec2-user/athena-app/docker-compose.yml\",
              \"echo '$ENV_BASE64' | base64 -d > .env\",
              \"export FRONTEND_IMAGE=${{ env.REGISTRY }}/${{ env.REPO }}:web-latest\",
              \"export BACKEND_IMAGE=${{ env.REGISTRY }}/${{ env.REPO }}:api-latest\",
              \"export RND_IMAGE=${{ env.REGISTRY }}/${{ env.REPO }}:rnd-latest\",
              \"docker compose pull athena-frontend\",
              \"docker compose up -d athena-frontend\",
              \"docker image prune -f\",
              \"docker ps\"
            ]}"

