name: "Multi-Repo 3-Tier Deployment"

on:
  workflow_dispatch:
    #inputs:
      #worker_branch:
        #description: 'Branch to pull from Repo 2'
        #required: true
        #default: 'main'
        #type: string

permissions:
  id-token: write
  contents: read

jobs:
  build:
    runs-on: ubuntu-latest
    strategy:
      matrix:
        include:
          - folder: "./frontend"
            tag: "web-latest"
          - folder: "./backend"
            tag: "api-latest"
          - folder: "./rnd-logic/rnd" 
            tag: "rnd-latest"
    steps:
      - name: Checkout Main Repo
        uses: actions/checkout@v4

      - name: Checkout Worker Repo
        uses: actions/checkout@v4
        with:
          repository: "abhishek095859/test-cross"
          token: ${{ secrets.APP_REPO_TOKEN }}
          path: "rnd-logic"
          #ref: ${{ github.event.inputs.worker_branch }}  ####this line is for GitHub actions pipeline select the branch in GitHub repo2.

      - name: Configure AWS credentials
        uses: aws-actions/configure-aws-credentials@v4
        with:
          role-to-assume: arn:aws:iam::185863138492:role/crossaccountb
          aws-region: ap-south-1

      - name: Login to ECR
        id: login-ecr
        uses: aws-actions/amazon-ecr-login@v2

      - name: Build and Push
        run: |
          REPO_NAME="atl_apac_mum_dtlk_prod_athena2.0_ecr_01"
          REGISTRY=${{ steps.login-ecr.outputs.registry }}
          FULL_IMAGE=$REGISTRY/$REPO_NAME:${{ matrix.tag }}
          docker build -t $FULL_IMAGE ${{ matrix.folder }}
          docker push $FULL_IMAGE

  deploy:
    needs: build
    runs-on: ubuntu-latest
    steps:
      - name: Checkout Main Repo
        uses: actions/checkout@v4

      - name: Configure AWS credentials
        uses: aws-actions/configure-aws-credentials@v4
        with:
          role-to-assume: arn:aws:iam::185863138492:role/crossaccountb
          aws-region: ap-south-1

      - name: Deploy Stack via SSM
        run: |
          COMPOSE_BASE64=$(base64 -w 0 docker-compose.yml)
          REGISTRY="185863138492.dkr.ecr.ap-south-1.amazonaws.com"
          REPO="atl_apac_mum_dtlk_prod_athena2.0_ecr_01"

          aws ssm send-command \
            --targets "Key=tag:project,Values=athena2.0" \
            --document-name "AWS-RunShellScript" \
            --parameters "{\"commands\":[
              \"aws ecr get-login-password --region ap-south-1 | docker login --username AWS --password-stdin $REGISTRY\",
              \"mkdir -p /home/ec2-user/athena-app\",
              \"echo '$COMPOSE_BASE64' | base64 -d > /home/ec2-user/athena-app/docker-compose.yml\",
              \"echo 'FRONTEND_IMAGE=$REGISTRY/$REPO:web-latest' > /home/ec2-user/athena-app/.env\",
              \"echo 'BACKEND_IMAGE=$REGISTRY/$REPO:api-latest' >> /home/ec2-user/athena-app/.env\",
              \"echo 'RND_IMAGE=$REGISTRY/$REPO:rnd-latest' >> /home/ec2-user/athena-app/.env\",
              \"cd /home/ec2-user/athena-app\",
              \"docker compose down\",
              \"docker compose pull\",
              \"docker compose up -d\",
              \"docker image prune -f\",
              \"docker ps\"
            ]}"



- name: Checkout Worker Repo
        uses: actions/checkout@v4
        with:
          repository: "abhishek095859/test-cross"
          token: ${{ secrets.APP_REPO_TOKEN }}
          path: "rnd-logic"
          ref: ${{ github.event.inputs.worker_branch }}


${{ secrets.APP_REPO_TOKEN }} : the app repo token which is access to  another GitHub repo because in real time we use private GitHub repos so GitHub repo 1 need to access the GitHub repo 2 due to the yaml file is in GitHub repo 1 so we use the secrets.

path : rnd-logic is when the git checkout to GitHub repo 2 it will take the code and store in rnd-logic path so it will build the image.

COMPOSE_BASE64=$(base64 -w 0 docker-compose.yml)

Reads docker-compose.yml
Converts it into a single-line encoded string
